		"oxfmt": "^0.40.0",
		"oxlint": "^1.55.0",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"dependencies": {
		"@codemirror/language": "^6.12.2",
		"@lezer/common": "^1.5.1",
		"beautiful-mermaid": "^1.1.3",
		"obsidian": "latest"
